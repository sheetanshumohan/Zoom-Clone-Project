# ============================================================
# Zoom Clone — .gitignore
# ============================================================

# ─── Python / FastAPI Backend ───────────────────────────────
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/**/*.pyd
*.pyc
*.pyo
*.pyd
__pycache__/
*.py[cod]

# SQLite Database (auto-created on first run — do not commit)
backend/zoom_clone.db
*.db
*.sqlite
*.sqlite3

# Python environment & packaging
*.egg-info/
dist/
build/
.eggs/
*.egg
.Python
pip-log.txt
pip-delete-this-directory.txt

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml

# ─── Next.js / Node Frontend ────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/

# Next.js cache
.next/
out/

# Node modules (root, if any)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# Build outputs
dist/
build/

# ─── Environment Variables ───────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
frontend/.env
frontend/.env.local
frontend/.env.production
backend/.env

# ─── OS / Editor Files ──────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# VSCode
.vscode/
*.code-workspace

# JetBrains IDEs
.idea/
*.iml
*.iws

# ─── Logs ───────────────────────────────────────────────────
logs/
*.log
lerna-debug.log*

# ─── Temporary / Misc ────────────────────────────────────────
*.tmp
*.temp
*.swp
*.swo
check_meeting_time.py
